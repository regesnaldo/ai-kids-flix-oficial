import { agents as rawAgents } from "@/data/agents";
import AgentCarousel from "@/components/AgentCarousel";
import HeroBanner from "@/components/HeroBanner";
import { AgentUI } from "@/types/agent";

const FALLBACK_COLORS = ["#E50914", "#54B435", "#3B82F6", "#8B5CF6", "#F59E0B"];

const mapToUI = (raw: any[]): AgentUI[] => {
  return raw.map((a, i) => ({
    id: a.id || `agent-${i}`,
    name: a.name || "Agente",
    role: a.role || "Mestre do Conhecimento",
    color: a.color || FALLBACK_COLORS[i % FALLBACK_COLORS.length],
    desc: a.description || a.desc || "Pronto para explorar o mundo da Inteligência Artificial.",
    tag: a.tag || "IA"
  }));
};

export default function HomePage() {
  const ALL_AGENTS = mapToUI(rawAgents);
  const heroAgent = ALL_AGENTS[0];
  const allNames = ALL_AGENTS.map(a => a.name);

  const categories = [
    { title: "Mestres Gregos", names: ["ETHOS", "LOGOS", "GNOSIS", "KAIROS"] },
    { title: "Populares no MENTE.AI", names: allNames.slice(0, 15) },
    { title: "Sugeridos para Você", names: allNames.slice(15, 35) }
  ];

  return (
    <main className="min-h-screen bg-black overflow-x-hidden">
      <HeroBanner agent={heroAgent} />
      
      {/* Espaçamento negativo para subir o carrossel igual à Netflix */}
      <div className="relative z-20 -mt-24 pb-20 space-y-12">
        {categories.map((cat, idx) => (
          <AgentCarousel 
            key={`row-${idx}`}
            title={cat.title}
            agentNames={cat.names}
            allAgents={ALL_AGENTS}
          />
        ))}
      </div>
    </main>
  );
}
