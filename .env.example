# Obrigatórias
JWT_SECRET=seu-secret-aqui
# TiDB local: mysql://root:@127.0.0.1:4000/mente_ai
# TiDB Cloud: mysql://<USER>:<PASSWORD>@<HOST>:4000/<DATABASE>
DATABASE_URL=sua-connection-string-do-banco
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA_PATH=certs/isrgrootx1.pem
STRIPE_SECRET_KEY=sua-chave-stripe
STRIPE_WEBHOOK_SECRET=seu-webhook-secret-stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=sua-chave-publica-stripe
RESEND_API_KEY=sua-chave-resend
RESEND_FROM_EMAIL=MENTE.AI <onboarding@seu-dominio.com>

# Opcionais (dev)
GOOGLE_AI_STUDIO_API_KEY=sua-chave-google
CHECKOUT_API_KEY=sua-chave-checkout
CHECKOUT_AUTHENTICATOR=seu-authenticator
