# .npmrc - Configuração do npm para MENTE.AI
# CORREÇÃO #09: Resolve warnings de ERESOLVE com dependências ESLint

legacy-peer-deps=true
engine-strict=false

# Opcional: ignora scripts de pós-instalação para builds mais rápidos
# ignore-scripts=true

# Registry padrão (pode ser alterado para mirror se necessário)
registry=https://registry.npmjs.org/

# Save exato para versões
save-exact=false
save-prefix=^
