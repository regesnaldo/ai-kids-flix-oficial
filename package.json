{
  "name": "mente-ai-platform",
  "version": "1.0.0",
  "description": "MENTE.AI — Plataforma de Inteligência Emocional e Autoconhecimento",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/clean-dev.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "quality": "npm run lint && npm run typecheck && npm run test:ci",
    "lighthouse": "lhci autorun",
    "arch:map": "npx madge --image docs/architecture/system-map.svg --layout dot --rankdir TB --extensions ts,tsx --ts-config ./tsconfig.json src/",
    "arch:circular": "npx madge --circular --json --extensions ts,tsx --ts-config ./tsconfig.json src/ > docs/architecture/circular-deps.json",
    "arch:modules": "npx madge --json --extensions ts,tsx --ts-config ./tsconfig.json src/ > docs/architecture/module-deps.json",
    "arch:heatmap": "node scripts/validation/generate-heatmap.js",
    "arch:validate": "npm run arch:circular && node scripts/validation/validate-no-circular.js",
    "arch:full": "npm run arch:map && npm run arch:circular && npm run arch:modules && npm run arch:heatmap",
    "agents:generate": "npx ts-node --esm scripts/generate-agents.ts",
    "agents:images": "npx ts-node --esm scripts/generate-agent-images.ts",
    "agents:images:batch": "npx ts-node --esm scripts/generate-agent-images.ts --batch 10",
    "agents:check": "npx ts-node --esm scripts/check-progress.ts",
    "agents:retry": "npm run agents:images",
    "agents:translate-names": "npx ts-node --esm scripts/translate-agent-names.ts",
    "automate:all": "npx ts-node --esm scripts/automate-everything.ts",
    "commit": "powershell -ExecutionPolicy Bypass -File ./scripts/commit-all.ps1",
    "commit:quick": "powershell -ExecutionPolicy Bypass -File ./scripts/quick-commit.ps1",
    "demo:record": "playwright test --grep \"Gravar demo\"",
    "precommit": "npm run arch:validate && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@types/three": "^0.183.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.574.0",
    "mysql2": "^3.18.2",
    "next": "16.1.6",
    "openai": "^4.77.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.4.1",
    "three": "^0.183.2",
    "tone": "^15.1.22",
    "web-vitals": "^5.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.0",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jest": "^30.3.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "madge": "^8.0.0",
    "playwright": "^1.58.2",
    "shadcn": "^3.8.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
